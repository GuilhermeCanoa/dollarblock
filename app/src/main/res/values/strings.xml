    <string name="home_info_damage_title">Today\'s Damage</string>
    <string name="home_info_damage_body">Your minutes in monitored apps today, converted to money: your net monthly salary (R$ 2,000 by default — add yours on the Home card) spread over the 43,200 minutes of the month. Not a fine — the market price of your scroll.</string>
    <string name="home_info_spent_title">Money Spent</string>
    <string name="home_info_spent_body">Everything you actually paid for day passes, since day one. Pulled straight from your unlock receipts. Real money — that was the deal.</string>
    <string name="home_info_saved_title">Money Saved</string>
    <string name="home_info_saved_body">Each day an app hit its limit and you left the block screen without paying counts as one day pass not bought, at today\'s rate. Days you paid don\'t count. Resisting is the only discount we offer.</string>
    <string name="home_info_blocked_title">Blocked Now</string>
    <string name="home_info_blocked_body">Monitored apps that hit their daily limit and are locked right now. The meter stopped; the bill is on the table.</string>
    <string name="home_info_addiction_title">Addiction Tracker</string>
    <string name="home_info_addiction_body">How many times you tried to open a blocked app today. Every attempt gets filed. We don\'t judge — we count.</string>
    <string name="home_no_events">No blocks today. The market is impressed.</string>
    <string name="home_event_blocked">Blocked %1$s</string>
    <string name="home_event_unlocked">Bailed out %1$s</string>
