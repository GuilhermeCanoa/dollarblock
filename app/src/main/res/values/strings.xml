    <!-- Onboarding (E2 — first run) -->
    <string name="onb_welcome_title">Time is money. Yours is leaking.</string>
    <string name="onb_welcome_body">Instagram, TikTok and YouTube have entire teams of engineers paid to keep you scrolling. DollarBlock puts a meter on them: pick the apps that eat your day, set a daily limit, and past that limit they lock.</string>
    <string name="onb_penalty_title">The deal</string>
    <string name="onb_penalty_body">Clause 1: you pick the apps. Clause 2: you set the limits. Clause 3: past the limit, the app locks — and if you really need it back, you pay R$ 1 for a day pass, valid until midnight. The money is real. That\'s the whole point. No sob stories: the idea was yours.</string>
    <string name="onb_contract_header">DOLLARBLOCK · AGREEMENT</string>
    <string name="onb_contract_footer">By taking the challenge, you agree to be billed for your own excuses.</string>
    <string name="onb_summary_title">Quick summary</string>
    <string name="onb_summary_body">These are the apps stealing your time — and, therefore, your money. They\'re the ones you\'ll want to go after.</string>
    <string name="onb_summary_total">Total</string>
    <string name="onb_summary_need_usage_title">Usage Access needed</string>
    <string name="onb_summary_need_usage_body">Allow DollarBlock to read your screen time so we can show your top apps here.</string>
    <string name="onb_summary_grant">Grant Usage Access</string>
    <string name="onb_permissions_title">The paperwork</string>
    <string name="onb_permissions_body">DollarBlock needs these permissions to measure usage and block apps. We only request what is strictly necessary — each one opens the corresponding system screen.</string>
    <string name="onb_perm_usage_why">Measures how much time you spend in each app — the foundation of everything.</string>
    <string name="onb_perm_accessibility_why">Detects the foreground app to apply the block.</string>
    <string name="onb_perm_overlay_why">Displays the block screen on top of the app.</string>
    <string name="onb_perm_notifications_why">Notifies you about limits reached and the monitoring service.</string>
    <string name="notif_channel_name">Limit warnings</string>
    <string name="notif_limit_warning_title">5 minutes of %1$s left</string>
    <string name="notif_limit_warning_body">Prepare the card, or your dignity.</string>
