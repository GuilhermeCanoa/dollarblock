    <!-- Onboarding (E2 — first run) -->
    <string name="onb_welcome_title">Discipline that pays off</string>
    <string name="onb_welcome_body">DollarBlock is your time coach. Choose the apps that distract you, set a daily limit and we take care of the rest: once you hit the limit, access is blocked.</string>
    <string name="onb_penalty_title">How the penalty works</string>
    <string name="onb_penalty_body">Really need to use an app after hitting the limit? You can unlock it instantly by paying a small penalty. That cost creates the friction that makes you think twice — and every minute saved counts.</string>
    <string name="onb_permissions_title">Let\'s set up the essentials</string>
    <string name="onb_permissions_body">DollarBlock needs these permissions to measure usage and block apps. We only request what is strictly necessary — each one opens the corresponding system screen.</string>
    <string name="onb_perm_usage_why">Measures how much time you spend in each app — the foundation of everything.</string>
    <string name="onb_perm_accessibility_why">Detects the foreground app to apply the block.</string>
    <string name="onb_perm_overlay_why">Displays the block screen on top of the app.</string>
    <string name="onb_perm_notifications_why">Notifies you about limits reached and the monitoring service.</string>
    <string name="onb_perm_required">required</string>
    <string name="onb_perm_grant">Grant</string>
