    <string name="onb_welcome_title">Disciplina que vale dinheiro</string>
    <string name="onb_welcome_body">O DollarBlock é seu treinador de tempo. Escolha os apps que te distraem, defina um limite diário e nós cuidamos do resto: passou do limite, o acesso é bloqueado.</string>
    <string name="onb_penalty_title">Como funciona a penalidade</string>
    <string name="onb_penalty_body">Precisa muito usar depois do limite? Você pode liberar na hora pagando uma pequena penalidade. Esse custo cria a fricção que te faz pensar duas vezes — e cada minuto economizado conta.</string>
    <string name="onb_permissions_title">Vamos liberar o essencial</string>
    <string name="onb_permissions_body">O DollarBlock precisa destas permissões para medir o uso e bloquear apps. Concedemos só o necessário — cada uma abre a tela do sistema correspondente.</string>
    <string name="onb_perm_usage_why">Mede quanto tempo você passa em cada app, base de tudo.</string>
    <string name="onb_perm_accessibility_why">Detecta o app em primeiro plano para aplicar o bloqueio.</string>
    <string name="onb_perm_overlay_why">Exibe a tela de bloqueio por cima do app.</string>
    <string name="onb_perm_notifications_why">Avisa sobre limites atingidos e o serviço de monitoramento.</string>
    <string name="onb_perm_required">obrigatória</string>
    <string name="onb_perm_grant">Conceder</string>
